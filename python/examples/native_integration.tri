fn fib(n) {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

let results = []
for i in range(10) {
    results.push(fib(i))
}

print(results)

let total = 0
for r in results {
    total = total + r
}
print(total)


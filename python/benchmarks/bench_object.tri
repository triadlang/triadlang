// Object creation and method call benchmark
type Point {
    x: Float;
    y: Float;

    fn distance(other) {
        import math;
        let dx = self.x - other.x;
        let dy = self.y - other.y;
        return math.sqrt(dx * dx + dy * dy);
    }
}

let total = 0.0;
for i in range(5000) {
    let p1 = Point(x=float(i), y=float(i * 2));
    let p2 = Point(x=float(i + 1), y=float(i * 2 + 1));
    total = total + p1.distance(p2);
}
print("object total = " + str(total));

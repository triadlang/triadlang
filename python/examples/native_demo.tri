fn factorial(n) {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

let result = factorial(10)
print(f"10! = {result}")

let nums = [10, 20, 30]
let sum = 0
for n in nums {
    sum = sum + n
}
print(f"sum = {sum}")

let data = {"name": "TriadLang", "year": 2026}
print(data["name"])
print(f"Born in {data["year"]}")

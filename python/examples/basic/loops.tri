// for loop
for i in range(5) {
    print(i);
}

// while loop
let x = 0;
while x < 5 {
    print("x = " + str(x));
    x = x + 1;
}

// nested loops
for i in range(3) {
    for j in range(3) {
        print(str(i) + "," + str(j));
    }
}

// loop with break
for i in range(100) {
    if i > 4 {
        break;
    }
    print("counting: " + str(i));
}
